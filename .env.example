# Atlas — environment variables
#
# Copy to `.env` (gitignored) and fill in. The atlas pipelines read this file
# at import time via python-dotenv.

# === Atlas DB (Supabase) ===
# Single connection string, used for both reads (public.de_*) and writes (atlas.*).
# Get the connection string from Supabase project settings → Database → Connection.
# Use the **transaction** pooler URI for compute jobs.
#
# Format: postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DB?sslmode=require
ATLAS_DB_URL=postgresql+psycopg2://atlas_writer:CHANGE_ME@db.PROJECT.supabase.co:6543/postgres?sslmode=require

# Pool sizing (defaults are fine for v0)
# ATLAS_DB_POOL_SIZE=5
# ATLAS_DB_MAX_OVERFLOW=10

# === Universe lock date ===
# Date stamped on every atlas_universe_*.effective_from row at M1 execution.
# Defaults to 2026-05-06 if unset.
# ATLAS_UNIVERSE_LOCK_DATE=2026-05-06

# === Slack alerts (optional) ===
# Webhook for #atlas-alerts. If empty, warnings are logged but not posted.
# ATLAS_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# === Legacy JIP connection (preserved for the M0-inventory module under
#     src/atlas_os/. Not used by the new atlas/ package.) ===
# JIP_DB_HOST=jip-data-engine.ctay2iewomaj.ap-south-1.rds.amazonaws.com
# JIP_DB_PORT=5432
# JIP_DB_NAME=data_engine
# JIP_DB_USER=jip_admin
# JIP_DB_PASSWORD=<set-this>
# JIP_DB_SSL_CA_PATH=./global-bundle.pem
