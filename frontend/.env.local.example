# frontend/.env.local.example
# Copy to .env.local and fill in values. Never commit .env.local.

# Supabase Postgres connection string (atlas schema)
ATLAS_DB_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Internal auth password — shown on /login
ATLAS_PASSWORD=change-me

# M13 Threshold Admin — internal recompute API on EC2 (.214:8002)
# Generate the secret once: openssl rand -hex 32
# The same value must live in /etc/systemd/system/atlas-internal-recompute.service.d/secret.conf on .214
ATLAS_INTERNAL_SECRET=change-me-64-hex-chars
ATLAS_INTERNAL_API_BASE_URL=http://13.206.34.214:8002
